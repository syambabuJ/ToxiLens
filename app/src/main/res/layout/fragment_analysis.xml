<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">


<TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Comment Analysis"
        android:textSize="24sp"
        android:fontFamily="@font/inter_semibold"
        android:textStyle="bold"
        android:textColor="@color/orange"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <com.example.yttoxicitychecker.utils.CanvasView
            android:id="@+id/canvasChart"
            android:layout_width="120dp"
            android:layout_height="120dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/textToxicCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔴 Toxic: 0"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/textNeutralCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🟡 Neutral: 0"
                android:fontFamily="@font/inter_regular"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/textSafeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:text="🟢 Safe: 0"
                android:textSize="14sp"/>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/textToxicityScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Overall Toxicity: 0%"
        android:textSize="16sp"
        android:fontFamily="@font/inter_medium"
        android:textStyle="bold"
        android:textColor="@color/orange"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/buttonRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter_medium"
        android:text="Refresh Analysis"
        android:backgroundTint="#86EFAC"
        android:textColor="@color/white"
        android:layout_marginBottom="16dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewComments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="4dp"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

</LinearLayout>