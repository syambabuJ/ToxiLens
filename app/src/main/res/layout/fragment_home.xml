<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/transparent">
   <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="ToxiLens"
    android:textSize="28sp"
    android:fontFamily="@font/inter_semibold"
    android:textColor="#0B3C91"
    android:letterSpacing="0.02"
    android:lineHeight="32sp"

    android:layout_marginBottom="20dp"/>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"

        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"

        android:backgroundTint="#CCFFFFFF"
        app:strokeColor="#40FFFFFF"
        app:strokeWidth="1dp"

        app:cardUseCompatPadding="true"
        app:cardPreventCornerOverlap="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- 🔷 Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter YouTube URL"
                android:textSize="18sp"
                android:fontFamily="@font/inter_semibold"
                android:textColor="#0B3C91"
                android:layout_marginBottom="10dp"/>

            <!-- 🔷 Input Field -->
            <EditText
                android:id="@+id/editTextUrl"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Paste YouTube link here..."
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:fontFamily="@font/inter_regular"
                android:textColor="#1F2937"
                android:textColorHint="#9CA3AF"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="18dp"
                android:inputType="textUri"
                android:imeOptions="actionDone"/>

            <!-- 🔷 Button -->
            <Button
                android:id="@+id/buttonAnalyze"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Analyze Comments"
                android:textAllCaps="false"
                android:fontFamily="@font/inter_semibold"
                android:backgroundTint="#22C55E"
                android:textColor="@android:color/white"
                android:elevation="2dp"
                android:stateListAnimator="@null"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ADD THIS - Video Title Display -->
    <TextView
        android:id="@+id/textVideoTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/blue"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:background="@color/light_gray"
        android:gravity="center_vertical"
        android:drawableStart="@drawable/ic_play_small"
        android:drawablePadding="8dp"/>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewComments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="4dp"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

</LinearLayout>
